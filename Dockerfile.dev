FROM node:24-alpine

WORKDIR /app

# Copy package files and install dependencies
COPY package.json package-lock.json* ./
RUN npm ci

# Source files are mounted as a volume at runtime
# so we don't COPY them here

EXPOSE 3000

ENV NODE_ENV=development
# Enable polling so Next.js detects file changes from bind-mounted volumes
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
